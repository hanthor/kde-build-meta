diff --git a/CMakeLists.txt b/CMakeLists.txt
index dbaaf3f7a..54f0c2f90 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -171,7 +171,10 @@ if (BUILD_MOBILE)
 endif()
 
 if(NOT WIN32 AND NOT ANDROID AND NOT APPLE AND NOT HAIKU)
-    set(HAVE_X11 TRUE)
+    find_package(X11)
