     set(HAVE_X11 FALSE)
 endif()
diff --git a/shell/shell.cpp b/shell/shell.cpp
index ca12cc32f..de0993d84 100644
--- a/shell/shell.cpp
+++ b/shell/shell.cpp
@@ -27,7 +27,7 @@
 #include <KSharedConfig>
 #include <KStandardAction>
-#if !defined(Q_OS_WIN) && !defined(Q_OS_OSX) && !defined(Q_OS_HAIKU)
+#if HAVE_X11 && !defined(Q_OS_WIN) && !defined(Q_OS_OSX) && !defined(Q_OS_HAIKU)
 #include <KStartupInfo>
 #include <KWindowInfo>
 #endif
@@ -452,7 +452,7 @@ bool Shell::canOpenDocs(int numDocs, int desktop)
         return false;
     }
 
-#if !defined(Q_OS_WIN) && !defined(Q_OS_OSX) && !defined(Q_OS_HAIKU)
