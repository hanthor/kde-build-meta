From: Copilot <223556219+Copilot@users.noreply.github.com>
Date: Sat, 2 May 2026 21:20:00 +0000
Subject: [PATCH] Check temporary file creation in Quick Commands

Newer Qt marks QTemporaryFile::open() as nodiscard. Handle failures
explicitly before running shellcheck.
---
 src/plugins/QuickCommands/quickcommandswidget.cpp | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/plugins/QuickCommands/quickcommandswidget.cpp b/src/plugins/QuickCommands/quickcommandswidget.cpp
index 7dd114f9..4d3fd18c 100644
--- a/src/plugins/QuickCommands/quickcommandswidget.cpp
+++ b/src/plugins/QuickCommands/quickcommandswidget.cpp
@@ -314,7 +314,12 @@ void QuickCommandsWidget::runShellCheck()
     }
 
     QTemporaryFile file;
-    file.open();
+    if (!file.open()) {
+        ui->warning->setPlainText(i18n("Failed to create a temporary file for shellcheck"));
+        ui->tabWidget->setTabText(1, i18n("Warnings (*)"));
+        return;
+    }
 
     QTextStream ts(&file);
     ts << "#!/bin/bash\n";
-- 
2.49.0
